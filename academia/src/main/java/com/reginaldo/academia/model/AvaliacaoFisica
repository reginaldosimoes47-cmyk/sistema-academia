package com.reginaldo.academia.model;

import jakarta.persistence.*;
import lombok.Data;
import java.util.List;
import java.util.ArrayList;

@Entity
@Data // O Lombok cria Getters/Setters sozinho (Certifique-se que o plugin está ativo no IntelliJ!)
@Table(name = "alunos")
public class Aluno {

     @Id
     @GeneratedValue(strategy = GenerationType.IDENTITY)
     private Long id;

     private String nome;
     private String email;
     private String cpf;
     private String rg;
     private String matricula;

     // --- CAMPOS ESSENCIAIS QUE ESTAVAM FALTANDO ---
     private Integer idade;
     private String plano;

     // Relacionamento: Um Aluno tem muitas Avaliações
     @OneToMany(mappedBy = "aluno", cascade = CascadeType.ALL, orphanRemoval = true)
     private List<AvaliacaoFisica> avaliacoes = new ArrayList<>();
}

